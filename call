#!/bin/bash
# high_speed_caller.sh - High-performance bulk calling tool

# ==================== CONFIGURATION ====================
# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
MAGENTA='\033[0;35m'
NC='\033[0m'

# Performance settings
MAX_CONCURRENT=50        # Max concurrent calls
RATE_LIMIT=10            # Default calls per second
BATCH_SIZE=100           # Numbers per batch
# =======================================================

# Show banner
show_banner() {
    echo -e "${MAGENTA}"
    cat << "EOF"
╔══════════════════════════════════════════════════════════╗
║     HIGH-SPEED NUMBER TOOL v3.0                         ║
║     Bulk Calling System | Rate Control | Concurrent     ║
╚══════════════════════════════════════════════════════════╝
EOF
    echo -e "${NC}"
}

# Detect OS
detect_os() {
    case "$(uname -s)" in
        Darwin) BROWSER_CMD="open" ;;
        Linux) BROWSER_CMD="xdg-open" ;;
        CYGWIN*|MINGW*|MSYS*) BROWSER_CMD="start" ;;
        *) BROWSER_CMD="open" ;;
    esac
}

# Clean phone number
clean_number() {
    echo "$1" | tr -cd '0-9' | sed 's/^1//' | cut -c1-10
}

# Generate random numbers (for testing)
generate_numbers() {
    local count=$1
    local prefix="${2:-555}"
    
    for i in $(seq 1 $count); do
        echo "${prefix}$(printf "%07d" $RANDOM | cut -c1-7)"
    done
}

# High-speed async call function
async_call() {
    local number="$1"
    local call_id="$2"
    local clean=$(clean_number "$number")
    
    # Add *67 to block caller ID
    local star67="*67${clean}"
    
    # Fire and forget - open browser tabs in background
    {
        $BROWSER_CMD "https://www.textnow.com/call?phone=${star67}" 2>/dev/null
        echo "$(date +%H:%M:%S.%3N) | Call #$call_id | $clean | *67" >> "$LOG_FILE"
    } &
}

# Rate-limited bulk caller
bulk_call_rate_limited() {
    local numbers_file="$1"
    local rate="$2"  # calls per second
    local concurrent="$3"
    
    local numbers=()
    while IFS= read -r line; do
        numbers+=("$line")
    done < "$numbers_file"
    
    local total=${#numbers[@]}
    local delay=$(echo "scale=3; 1 / $rate" | bc)
    
    echo -e "${GREEN}⚡ High-Speed Mode:${NC}"
    echo -e "  Total numbers: $total"
    echo -e "  Target rate: $rate calls/second"
    echo -e "  Delay: $delay seconds between calls"
    echo -e "  Concurrent: Up to $concurrent tabs"
    echo ""
    
    local start_time=$(date +%s)
    local success=0
    
    for i in "${!numbers[@]}"; do
        async_call "${numbers[$i]}" "$((i+1))"
        ((success++))
        
        # Rate limiting
        if [ $(echo "$delay < 0.1" | bc) -eq 1 ]; then
            # For high rates, use microsecond sleep
            usleep=$(echo "$delay * 1000000" | bc | cut -d. -f1)
            usleep $usleep 2>/dev/null || sleep $delay
        else
            sleep $delay
        fi
        
        # Show progress every 100 calls
        if [ $((i % 100)) -eq 0 ] && [ $i -gt 0 ]; then
            local elapsed=$(($(date +%s) - start_time))
            local current_rate=$(echo "scale=1; $i / $elapsed" | bc)
            echo -e "${CYAN}Progress: $i/$total calls | Rate: $current_rate calls/sec${NC}"
        fi
    done
    
    local elapsed=$(($(date +%s) - start_time))
    local final_rate=$(echo "scale=1; $success / $elapsed" | bc)
    
    echo -e "\n${GREEN}✓ Completed: $success calls in ${elapsed}s (${final_rate} calls/sec)${NC}"
}

# Concurrent batch caller
bulk_call_concurrent() {
    local numbers_file="$1"
    local batch_size="$2"
    local concurrent="$3"
    
    local numbers=()
    while IFS= read -r line; do
        numbers+=("$line")
    done < "$numbers_file"
    
    local total=${#numbers[@]}
    local batches=$(( (total + batch_size - 1) / batch_size ))
    
    echo -e "${GREEN}⚡ Concurrent Mode:${NC}"
    echo -e "  Total numbers: $total"
    echo -e "  Batch size: $batch_size"
    echo -e "  Concurrent per batch: $concurrent"
    echo -e "  Total batches: $batches"
    echo ""
    
    local start_time=$(date +%s)
    local success=0
    
    for ((batch=0; batch<batches; batch++)); do
        local start_idx=$((batch * batch_size))
        local end_idx=$((start_idx + batch_size))
        [ $end_idx -gt $total ] && end_idx=$total
        
        local batch_numbers=("${numbers[@]:$start_idx:$((end_idx - start_idx))}")
        
        echo -e "${YELLOW}Batch $((batch+1))/$batches: Launching ${#batch_numbers[@]} calls${NC}"
        
        # Launch batch concurrently
        for i in "${!batch_numbers[@]}"; do
            async_call "${batch_numbers[$i]}" "$((start_idx + i + 1))"
            ((success++))
        done
        
        # Wait for batch to complete
        wait
        
        echo -e "${GREEN}Batch $((batch+1)) complete${NC}"
        
        # Small pause between batches
        sleep 1
    done
    
    local elapsed=$(($(date +%s) - start_time))
    local final_rate=$(echo "scale=1; $success / $elapsed" | bc)
    
    echo -e "\n${GREEN}✓ Completed: $success calls in ${elapsed}s (${final_rate} calls/sec)${NC}"
}

# High-speed burst mode (no rate limiting)
bulk_call_burst() {
    local numbers_file="$1"
    
    local numbers=()
    while IFS= read -r line; do
        numbers+=("$line")
    done < "$numbers_file"
    
    local total=${#numbers[@]}
    
    echo -e "${RED}⚡⚡ BURST MODE ⚡⚡${NC}"
    echo -e "${YELLOW}⚠️  No rate limiting - launching all calls simultaneously!${NC}"
    echo -e "  Total numbers: $total"
    echo -e "  This will open $total browser tabs instantly!"
    echo ""
    
    read -p "Are you sure? (yes/no): " confirm
    if [ "$confirm" != "yes" ]; then
        echo "Cancelled."
        return
    fi
    
    local start_time=$(date +%s)
    
    # Launch all calls at once
    for i in "${!numbers[@]}"; do
        async_call "${numbers[$i]}" "$((i+1))"
    done
    
    local elapsed=$(($(date +%s) - start_time))
    
    echo -e "\n${GREEN}✓ Launched $total calls in ${elapsed}s (${total} calls/sec)${NC}"
    echo -e "${YELLOW}⚠️  Browser may become overwhelmed!${NC}"
}

# Generate test numbers
generate_test_numbers() {
    local count="$1"
    local output_file="$2"
    
    echo -e "${CYAN}Generating $count test numbers...${NC}"
    > "$output_file"
    
    for i in $(seq 1 $count); do
        # Generate random 10-digit number
        area_code=$((200 + RANDOM % 800))
        prefix=$((200 + RANDOM % 800))
        line=$((0 + RANDOM % 9999))
        printf "%03d%03d%04d\n" $area_code $prefix $line >> "$output_file"
    done
    
    echo -e "${GREEN}✓ Generated $count numbers to $output_file${NC}"
}

# Performance test
performance_test() {
    local duration="$1"
    local rate="$2"
    
    echo -e "${CYAN}Performance Test: $duration seconds at $rate calls/sec${NC}"
    echo -e "${YELLOW}This will test your system's maximum call rate${NC}"
    echo ""
    
    local test_file=$(mktemp)
    local total_calls=$((duration * rate))
    
    # Generate test numbers
    generate_test_numbers $total_calls "$test_file"
    
    echo -e "\n${GREEN}Starting test...${NC}"
    local start_time=$(date +%s.%N)
    
    bulk_call_rate_limited "$test_file" "$rate" "$MAX_CONCURRENT"
    
    local end_time=$(date +%s.%N)
    local elapsed=$(echo "$end_time - $start_time" | bc)
    local actual_rate=$(echo "scale=1; $total_calls / $elapsed" | bc)
    
    echo -e "\n${GREEN}=== Performance Results ===${NC}"
    echo -e "Target: $rate calls/sec"
    echo -e "Actual: $actual_rate calls/sec"
    echo -e "Duration: ${elapsed}s"
    echo -e "Total: $total_calls calls"
    
    rm -f "$test_file"
}

# Show status dashboard
show_dashboard() {
    clear
    show_banner
    
    echo -e "${CYAN}╔══════════════════════════════════════════════════════════╗${NC}"
    echo -e "${CYAN}║                    SYSTEM STATUS                         ║${NC}"
    echo -e "${CYAN}╚══════════════════════════════════════════════════════════╝${NC}"
    echo ""
    
    # System info
    echo -e "${GREEN}System:${NC}"
    echo -e "  OS: $(uname -s)"
    echo -e "  CPU Cores: $(sysctl -n hw.ncpu 2>/dev/null || nproc 2>/dev/null || echo 'N/A')"
    echo -e "  Memory: $(vm_stat 2>/dev/null | grep 'Pages free' | awk '{print $3}' || free -h 2>/dev/null | grep Mem | awk '{print $4}')"
    echo ""
    
    # Browser check
    echo -e "${GREEN}Browser:${NC}"
    if command -v $BROWSER_CMD &> /dev/null; then
        echo -e "  ✓ $BROWSER_CMD available"
    else
        echo -e "  ✗ Browser command not found"
    fi
    echo ""
    
    # Performance metrics
    echo -e "${GREEN}Performance Capabilities:${NC}"
    echo -e "  Max concurrent: $MAX_CONCURRENT tabs"
    echo -e "  Rate limit: $RATE_LIMIT calls/sec"
    echo -e "  Batch size: $BATCH_SIZE numbers"
    echo ""
    
    # Recent calls
    if [ -f "$LOG_FILE" ] && [ -s "$LOG_FILE" ]; then
        echo -e "${GREEN}Recent Calls (last 5):${NC}"
        tail -5 "$LOG_FILE" | while read line; do
            echo -e "  $line"
        done
        echo ""
    fi
}

# Interactive control panel
control_panel() {
    while true; do
        clear
        show_banner
        echo -e "${CYAN}╔══════════════════════════════════════════════════════════╗${NC}"
        echo -e "${CYAN}║                   CONTROL PANEL                         ║${NC}"
        echo -e "${CYAN}╚══════════════════════════════════════════════════════════╝${NC}"
        echo ""
        echo -e "${GREEN}1)${NC} Rate-limited mode (control speed)"
        echo -e "${GREEN}2)${NC} Concurrent batch mode"
        echo -e "${GREEN}3)${NC} Burst mode (maximum speed)"
        echo -e "${GREEN}4)${NC} Generate test numbers"
        echo -e "${GREEN}5)${NC} Performance test"
        echo -e "${GREEN}6)${NC} Show dashboard"
        echo -e "${GREEN}7)${NC} Configure settings"
        echo -e "${RED}0)${NC} Exit"
        echo ""
        read -p "Select option: " choice
        
        case $choice in
            1)
                read -p "Numbers file: " file
                read -p "Calls per second (default $RATE_LIMIT): " rate
                rate=${rate:-$RATE_LIMIT}
                bulk_call_rate_limited "$file" "$rate" "$MAX_CONCURRENT"
                read -p "Press Enter to continue..."
                ;;
            2)
                read -p "Numbers file: " file
                read -p "Batch size (default $BATCH_SIZE): " batch
                batch=${batch:-$BATCH_SIZE}
                bulk_call_concurrent "$file" "$batch" "$MAX_CONCURRENT"
                read -p "Press Enter to continue..."
                ;;
            3)
                read -p "Numbers file: " file
                bulk_call_burst "$file"
                read -p "Press Enter to continue..."
                ;;
            4)
                read -p "How many test numbers: " count
                read -p "Output file: " file
                generate_test_numbers "$count" "$file"
                read -p "Press Enter to continue..."
                ;;
            5)
                read -p "Test duration (seconds): " duration
                read -p "Target rate (calls/sec): " rate
                performance_test "$duration" "$rate"
                read -p "Press Enter to continue..."
                ;;
            6)
                show_dashboard
                read -p "Press Enter to continue..."
                ;;
            7)
                configure_settings
                ;;
            0)
                exit 0
                ;;
        esac
    done
}

# Configure settings
configure_settings() {
    echo -e "\n${GREEN}Current Settings:${NC}"
    echo -e "  Max concurrent: $MAX_CONCURRENT"
    echo -e "  Rate limit: $RATE_LIMIT calls/sec"
    echo -e "  Batch size: $BATCH_SIZE"
    echo ""
    
    read -p "New max concurrent (default $MAX_CONCURRENT): " new_concurrent
    MAX_CONCURRENT=${new_concurrent:-$MAX_CONCURRENT}
    
    read -p "New rate limit (default $RATE_LIMIT): " new_rate
    RATE_LIMIT=${new_rate:-$RATE_LIMIT}
    
    read -p "New batch size (default $BATCH_SIZE): " new_batch
    BATCH_SIZE=${new_batch:-$BATCH_SIZE}
    
    echo -e "${GREEN}Settings updated!${NC}"
    sleep 1
}

# Show help
show_help() {
    show_banner
    cat << EOF
${GREEN}HIGH-SPEED NUMBER TOOL - Bulk Calling System${NC}

${YELLOW}USAGE:${NC}
    $0 [MODE] [OPTIONS] [FILE|NUMBER]

${YELLOW}MODES:${NC}
    --rate RATE        Rate-limited mode (calls per second)
    --batch SIZE       Concurrent batch mode
    --burst            Burst mode (no rate limit, maximum speed)
    --test             Generate test numbers
    --perf             Performance test
    --dashboard        Show system dashboard
    --interactive      Interactive control panel
    --config           Configure settings

${YELLOW}EXAMPLES:${NC}
    # Call 1000 numbers at 10 calls/second
    $0 --rate 10 numbers.txt
    
    # Call numbers in batches of 500
    $0 --batch 500 numbers.txt
    
    # Burst mode - all calls at once
    $0 --burst numbers.txt
    
    # Generate 10000 test numbers
    $0 --test 10000 test_numbers.txt
    
    # Performance test: 60 seconds at 20 calls/sec
    $0 --perf 60 20
    
    # Interactive control panel
    $0 --interactive

${YELLOW}SPEED CAPABILITIES:${NC}
    ⚡ Rate-limited: Up to 100 calls/second
    ⚡ Concurrent: Up to 1000 simultaneous calls
    ⚡ Burst: Unlimited (system dependent)
    
${YELLOW}FEATURES:${NC}
    ✓ Auto *67 on all calls (caller ID blocked)
    ✓ Rate control (calls per second)
    ✓ Concurrent batch processing
    ✓ Burst mode for maximum speed
    ✓ Performance testing
    ✓ Real-time metrics
    ✓ Call logging

${YELLOW}WARNING:${NC}
    High-speed calling may trigger spam detection
    Use responsibly and respect phone number privacy
    TextNow has daily call limits (typically 50-100)

EOF
}

# Main
main() {
    show_banner
    detect_os
    
    LOG_FILE="calls_$(date +%Y%m%d_%H%M%S).log"
    
    case "$1" in
        --rate)
            rate="$2"
            file="$3"
            bulk_call_rate_limited "$file" "$rate" "$MAX_CONCURRENT"
            ;;
        --batch)
            batch="$2"
            file="$3"
            bulk_call_concurrent "$file" "$batch" "$MAX_CONCURRENT"
            ;;
        --burst)
            file="$2"
            bulk_call_burst "$file"
            ;;
        --test)
            count="$2"
            output="$3"
            generate_test_numbers "$count" "$output"
            ;;
        --perf)
            duration="$2"
            rate="$3"
            performance_test "$duration" "$rate"
            ;;
        --dashboard)
            show_dashboard
            ;;
        --interactive)
            control_panel
            ;;
        --config)
            configure_settings
            ;;
        -h|--help)
            show_help
            ;;
        *)
            if [ -f "$1" ]; then
                # Default to rate-limited mode
                bulk_call_rate_limited "$1" "$RATE_LIMIT" "$MAX_CONCURRENT"
            else
                show_help
            fi
            ;;
    esac
}

main "$@"
