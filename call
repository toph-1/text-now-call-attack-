#!/bin/bash
# simple_textnow_caller.sh - Simple working version

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

# Show header
echo -e "${GREEN}================================${NC}"
echo -e "${GREEN}TextNow Auto Caller with *67${NC}"
echo -e "${GREEN}================================${NC}"
echo ""

# Function to clean phone numbers
clean_number() {
    echo "$1" | tr -cd '0-9' | sed 's/^1//' | cut -c1-10
}

# Function to make call
make_call() {
    local number=$1
    local count=$2
    
    # Add *67 to block caller ID
    local star67_number="*67${number}"
    
    echo -e "${YELLOW}[$count] Calling $number with *67...${NC}"
    
    # Try multiple methods to open the call
    
    # Method 1: Open TextNow website with the number
    open "https://www.textnow.com/call?phone=${star67_number}" 2>/dev/null
    
    # Method 2: Also try direct tel link
    open "tel:${star67_number}" 2>/dev/null
    
    echo -e "${GREEN}✓ Opened in browser - Click the call button${NC}"
    echo -e "${BLUE}  ↳ Your number is BLOCKED (*67)${NC}"
    echo ""
}

# Check if file was provided
if [ "$1" = "" ]; then
    echo -e "${RED}ERROR: No file specified!${NC}"
    echo ""
    echo "Usage:"
    echo "  ./simple_textnow_caller.sh numbers.txt"
    echo ""
    echo "Or create a file first:"
    echo "  echo \"5551234567\" > numbers.txt"
    echo "  echo \"5559876543\" >> numbers.txt"
    echo "  ./simple_textnow_caller.sh numbers.txt"
    echo ""
    exit 1
fi

# Check if file exists
if [ ! -f "$1" ]; then
    echo -e "${RED}ERROR: File '$1' not found!${NC}"
    echo ""
    echo "Current directory: $(pwd)"
    echo "Files in this directory:"
    ls -la
    echo ""
    echo "Create a file called numbers.txt with your numbers:"
    echo "  echo \"5551234567\" > numbers.txt"
    echo "  echo \"5559876543\" >> numbers.txt"
    echo ""
    exit 1
fi

# Read the file
echo -e "${GREEN}Reading numbers from: $1${NC}"
echo ""

# Show the contents of the file
echo -e "${BLUE}File contents:${NC}"
cat "$1"
echo ""

# Extract numbers
numbers=$(grep -oE '[0-9]{10}' "$1" | sort -u)

if [ -z "$numbers" ]; then
    echo -e "${RED}No valid 10-digit numbers found in file!${NC}"
    echo ""
    echo "Make sure your file has numbers like:"
    echo "  5551234567"
    echo "  555-987-6543"
    echo "  (555) 555-5555"
    exit 1
fi

# Count numbers
count=$(echo "$numbers" | wc -l | tr -d ' ')
echo -e "${GREEN}Found $count valid number(s):${NC}"
echo "$numbers" | while read num; do
    echo "  ✓ $num"
done
echo ""

# Confirm
read -p "Start calling these $count numbers? (y/n): " confirm
if [[ ! "$confirm" =~ ^[Yy]$ ]]; then
    echo "Cancelled."
    exit 0
fi

echo ""
echo -e "${GREEN}Starting calls...${NC}"
echo ""

# Make the calls
call_number=1
echo "$numbers" | while read number; do
    make_call "$number" "$call_number"
    
    # Wait between calls
    if [ $call_number -lt $count ]; then
        echo -e "${BLUE}Waiting 15 seconds before next call...${NC}"
        sleep 15
        echo ""
    fi
    
    ((call_number++))
done

echo -e "${GREEN}================================${NC}"
echo -e "${GREEN}All calls initiated!${NC}"
echo -e "${GREEN}================================${NC}"
echo ""
echo "✅ Each call was made with *67 (Caller ID Blocked)"
echo "📱 Browser tabs should open for each number"
echo "🔘 Click the call button in each tab to start the call"
